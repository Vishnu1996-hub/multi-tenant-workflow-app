# Ignore node_modules in both client and server directories
client/node_modules/
server/node_modules/
turbo/node_modules/

# Ignore build outputs
client/dist/
server/dist/
turbo/dist/

# Ignore environment variable files
client/.env
server/.env
turbo/.env

# Ignore logs
client/logs/
server/logs/
turbo/logs/
client/*.log
server/*.log
turbo/*.log

# Ignore temporary files
client/tmp/
server/tmp/
turbo/tmp/

# Ignore IDE/editor specific files
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
